{"nodes": [{"id": "fix_cc_stream_assembly_design", "label": "Chat Completions Stream Assembly Fix Design", "file_type": "document", "source_file": "openspec/changes/archive/2026-04-09-fix-chat-completions-stream-tool-call-assembly/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "stream_assembler_state_model", "label": "Indexed Stream Assembler State Model", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-04-09-fix-chat-completions-stream-tool-call-assembly/design.md", "source_location": "line 32", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Separate transport parsing from semantic assembly; key state by choice.index and tool_call.index to match provider-native schema and prevent cross-choice/cross-tool state corruption."}, {"id": "semantic_completion_markers", "label": "Semantic Completion Marker Strategy", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-04-09-fix-chat-completions-stream-tool-call-assembly/design.md", "source_location": "line 49", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Use finish_reason as primary completion boundary per choice, with [DONE] as final safety flush. Process all deltas in a chunk before flushing."}, {"id": "completed_only_toolcall_events", "label": "Completed-Only ProviderEvent::ToolCall Policy", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-04-09-fix-chat-completions-stream-tool-call-assembly/design.md", "source_location": "line 67", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "ProviderEvent::ToolCall must only be emitted when a tool call is semantically complete. Arguments parsed once at flush time; fallback to raw string if JSON invalid."}, {"id": "incremental_text_independence", "label": "Incremental Text Output Independence", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-04-09-fix-chat-completions-stream-tool-call-assembly/design.md", "source_location": "line 81", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Text deltas emit ProviderEvent::Output immediately regardless of pending tool-call assembly state to preserve low-latency streaming."}, {"id": "toolcall_index_order_emission", "label": "Tool Call Index Order Emission", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-04-09-fix-chat-completions-stream-tool-call-assembly/design.md", "source_location": "line 122", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Finalized tool calls emitted in ascending tool-call index order before ProviderEvent::Complete for deterministic regression tests."}, {"id": "best_effort_finalization", "label": "Best-Effort Metadata Finalization", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-04-09-fix-chat-completions-stream-tool-call-assembly/design.md", "source_location": "line 136", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "If provider omits/delays tool-call id or name, preserve latest non-empty values and emit best-effort completed event rather than failing the stream."}], "edges": [{"source": "fix_cc_stream_assembly_design", "target": "fix_cc_stream_assembly_tasks", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-04-09-fix-chat-completions-stream-tool-call-assembly/design.md", "source_location": null, "weight": 1.0}, {"source": "fix_cc_stream_assembly_design", "target": "cc_stream_assembly_spec_archive", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-04-09-fix-chat-completions-stream-tool-call-assembly/design.md", "source_location": null, "weight": 1.0}, {"s