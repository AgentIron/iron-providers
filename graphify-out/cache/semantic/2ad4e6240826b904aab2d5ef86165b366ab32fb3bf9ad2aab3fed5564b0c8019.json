{"nodes": [{"id": "oauth_credential_design", "label": "Provider Credential OAuth Design", "file_type": "document", "source_file": "openspec/changes/add-provider-credential-oauth/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "credential_kind_separation", "label": "Credential Kind vs Wire Auth Strategy Separation", "file_type": "rationale", "source_file": "openspec/changes/add-provider-credential-oauth/design.md", "source_location": "line 44", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "CredentialKind (ApiKey/OAuthBearer) and AuthStrategy (BearerToken/ApiKeyHeader) are separate axes. kimi-code proves they differ: API key uses x-api-key, OAuth uses Bearer token."}, {"id": "codex_separate_provider", "label": "Codex as Separate Provider from OpenAI", "file_type": "rationale", "source_file": "openspec/changes/add-provider-credential-oauth/design.md", "source_location": "line 202", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Codex uses ChatGPT/Codex backend endpoints, not public OpenAI API. Separate ApiFamily::CodexResponses keeps exact request requirements testable without bending existing OpenAI adapters."}, {"id": "jwt_routing_metadata", "label": "Unverified JWT Routing Metadata Extraction", "file_type": "rationale", "source_file": "openspec/changes/add-provider-credential-oauth/design.md", "source_location": "line 265", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Parse JWT payloads unverified for chatgpt_account_id routing header only; provider servers still validate bearer tokens. Claim priority: top-level chatgpt_account_id > nested https://api.openai.com/auth.chatgpt_account_id > organizations[].id."}, {"id": "oauth_lifecycle_boundary", "label": "OAuth Refresh Lifecycle Ownership Boundary", "file_type": "rationale", "source_file": "openspec/changes/add-provider-credential-oauth/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "iron-providers receives credential snapshots from iron-core/application but does not own OAuth refresh tokens or flows. ProviderCredential has no refresh_token field."}], "edges": [{"source": "oauth_credential_design", "target": "oauth_credential_tasks", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/add-provider-credential-oauth/design.md", "source_location": null, "weight": 1.0}, {"source": "oauth_credential_design", "target": "oauth_credential_spec", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/add-provider-credential-oauth/design.md", "source_location": null, "weight": 1.0}, {"source": "oauth_credential_design", "target": "credential_kind_separation", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/add-provider-credential-oauth/design.md", "source_location": null, "weight": 1.0}, {"source": "oauth_credential_design", "target": "codex_separate_provider", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/add-provider-credential-oauth/design.md", "source_location": null, "weight": 1.0}, {"source": "oauth_credential_design", "target": "jwt_routing_metadata", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/add-provider-credential-oauth/design.md", "source_location": null, "weight": 1.0}, {"source": "oauth_credential_design", "target": "oauth_lifecycle_boundary", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/add-provider-credential-oauth/design.md", "source_location": null, "weight": 1.0}, {"source": "credential_kind_separati